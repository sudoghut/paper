---
import BaseLayout from './BaseLayout.astro';
import 'katex/dist/katex.min.css';
import type { CollectionEntry } from 'astro:content';

interface Props {
  paper: CollectionEntry<'papers'>;
}
const { paper } = Astro.props;
const { title, originalTitle, originalUrl, authors, institution, hfVotes, publishDate, reviewDate, tags, description } = paper.data;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={title} description={description}>
  <a href={base || '/'} class="back-link">← 返回列表</a>

  <article>
    <header class="paper-header">
      <h1 class="paper-title">{title}</h1>
      <p class="paper-original-title">{originalTitle}</p>

      <div class="paper-meta-table">
        <span class="meta-key">原文作者</span>
        <span class="meta-val">{authors}</span>

        {institution && (
          <>
            <span class="meta-key">机构</span>
            <span class="meta-val">{institution}</span>
          </>
        )}

        <span class="meta-key">论文发布</span>
        <span class="meta-val">{publishDate}</span>

        <span class="meta-key">综述日期</span>
        <span class="meta-val">{reviewDate}</span>

        {hfVotes !== undefined && (
          <>
            <span class="meta-key">HF 票数</span>
            <span class="meta-val">🔺 {hfVotes}</span>
          </>
        )}
      </div>

      {tags && tags.length > 0 && (
        <div class="paper-tags">
          {tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      )}

      <a href={originalUrl} target="_blank" rel="noopener noreferrer" class="paper-original-link">
        📄 查看原文 →
      </a>
    </header>

    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<link is:inline rel="stylesheet" href="https://cdn.jsdelivr.net/npm/markmap-view@0.17/dist/browser/index.css" />
<script is:inline src="https://cdn.jsdelivr.net/npm/d3@7/dist/d3.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/markmap-lib@0.17/dist/browser/index.iife.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/markmap-view@0.17/dist/browser/index.js"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var transformer = new markmap.Transformer();

    document.querySelectorAll('pre[data-language="mermaid"]').forEach(function (pre) {
      // Convert Mermaid indented mindmap syntax → Markdown headings for markmap
      var md = mermaidToMarkdown(pre.textContent.trim());
      var result = transformer.transform(md);

      var wrapper = document.createElement('div');
      wrapper.className = 'markmap-wrapper';

      var hint = document.createElement('p');
      hint.className = 'markmap-hint';
      hint.textContent = 'Ctrl + 滚轮缩放 · 拖拽平移 · 双指缩放 · 点击节点折叠/展开';
      wrapper.appendChild(hint);

      var svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
      svg.style.width = '100%';
      svg.style.height = '680px';
      wrapper.appendChild(svg);

      // Floating hint overlay — shown when user uses wrong gesture
      var overlay = document.createElement('div');
      overlay.className = 'markmap-overlay-hint';
      wrapper.appendChild(overlay);

      pre.replaceWith(wrapper);

      var mm = markmap.Markmap.create(svg, {
        colorFreezeLevel: 2,   // each top-level branch → its own color, all descendants inherit it
        duration: 350,
        maxWidth: 380,
        spacingHorizontal: 72,
        spacingVertical: 4,
        paddingX: 16,
        zoom: true,
        pan: true,
      }, result.root);

      // Override d3-zoom filter: safety-net so the transform is only updated
      // on Ctrl+wheel / two-finger pinch (belt-and-suspenders with the capture below).
      mm.zoom.filter(function (event) {
        if (event.type === 'wheel') return event.ctrlKey || event.metaKey;
        if (event.type === 'touchstart') return event.touches.length > 1;
        return !event.button;
      });

      // Show / auto-hide the floating hint
      var hideTimer;
      function showOverlay(msg) {
        clearTimeout(hideTimer);
        overlay.textContent = msg;
        overlay.classList.add('visible');
        hideTimer = setTimeout(function () { overlay.classList.remove('visible'); }, 1800);
      }

      // Show / auto-hide the floating hint
      // Capture on PARENT (wrapper) so our listener runs in the capture phase,
      // before the SVG and any of its listeners (including d3-zoom's non-passive
      // wheel handler).  stopImmediatePropagation() prevents the SVG from receiving
      // the event at all — this blocks both d3-zoom and any browser SVG-scroll
      // container behaviour.  passive:true tells the browser it may scroll the
      // page immediately without waiting for this listener to finish.
      wrapper.addEventListener('wheel', function (e) {
        if (!e.ctrlKey && !e.metaKey) {
          e.stopImmediatePropagation();
          showOverlay('按住 Ctrl 并滚动以缩放');
        }
      }, { capture: true, passive: true });

      // touch-action:pan-x pan-y on the SVG (set in CSS) allows the browser to
      // scroll the page on single-touch without JavaScript intervention.
      // This passive listener only shows the hint.
      wrapper.addEventListener('touchstart', function (e) {
        if (e.touches.length === 1) showOverlay('双指操作可缩放思维导图');
      }, { passive: true });

      // markmap-view registers handlePan on the SVG for every wheel event when
      // pan:true.  handlePan translates the mindmap by deltaX/deltaY and calls
      // preventDefault(), which blocks page scroll.  Remove it so plain wheel
      // scrolls the page; mouse-drag panning (d3-zoom mousemoved) is unaffected.
      mm.svg.on('wheel', null);

      // Override d3-zoom's inline touch-action:none with inline !important so
      // single-touch scroll passes through to the page on mobile.  Must be inline
      // !important to beat d3-zoom's plain inline style set during initialisation.
      svg.style.setProperty('touch-action', 'pan-x pan-y', 'important');

      // Slight delay so the SVG is laid out before fit()
      setTimeout(function () { mm.fit(); }, 50);
    });

    function mermaidToMarkdown(text) {
      var lines = text.split('\n').filter(function (l) {
        return l.trim() && l.trim() !== 'mindmap';
      });
      var md = '';
      var indentStack = [];

      lines.forEach(function (line) {
        var indent = line.search(/\S/);
        if (indent < 0) return;
        while (indentStack.length && indentStack[indentStack.length - 1] >= indent) {
          indentStack.pop();
        }
        var depth = indentStack.length;
        indentStack.push(indent);

        // Strip Mermaid shape markers: root((x)), ((x)), (x), [x], {{x}}
        var name = line.trim()
          .replace(/^root\(\((.+)\)\)\s*$/, '$1')
          .replace(/^\(\((.+)\)\)\s*$/, '$1')
          .replace(/^\((.+)\)\s*$/, '$1')
          .replace(/^\[(.+)\]\s*$/, '$1')
          .replace(/^\{\{(.+)\}\}\s*$/, '$1');

        md += '#'.repeat(Math.min(depth + 1, 6)) + ' ' + name + '\n';
      });

      return md;
    }
  });
</script>
