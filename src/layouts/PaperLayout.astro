---
import BaseLayout from './BaseLayout.astro';
import 'katex/dist/katex.min.css';
import type { CollectionEntry } from 'astro:content';

interface Props {
  paper: CollectionEntry<'papers'>;
}
const { paper } = Astro.props;
const { title, originalTitle, originalUrl, authors, institution, hfVotes, publishDate, reviewDate, tags, description } = paper.data;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={title} description={description}>
  <a href={base || '/'} class="back-link">← 返回列表</a>

  <article>
    <header class="paper-header">
      <h1 class="paper-title">{title}</h1>
      <p class="paper-original-title">{originalTitle}</p>

      <div class="paper-meta-table">
        <span class="meta-key">原文作者</span>
        <span class="meta-val">{authors}</span>

        {institution && (
          <>
            <span class="meta-key">机构</span>
            <span class="meta-val">{institution}</span>
          </>
        )}

        <span class="meta-key">论文发布</span>
        <span class="meta-val">{publishDate}</span>

        <span class="meta-key">综述日期</span>
        <span class="meta-val">{reviewDate}</span>

        {hfVotes !== undefined && (
          <>
            <span class="meta-key">HF 票数</span>
            <span class="meta-val">🔺 {hfVotes}</span>
          </>
        )}
      </div>

      {tags && tags.length > 0 && (
        <div class="paper-tags">
          {tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      )}

      <a href={originalUrl} target="_blank" rel="noopener noreferrer" class="paper-original-link">
        📄 查看原文 →
      </a>
    </header>

    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<script type="module">
  import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';
  mermaid.initialize({ startOnLoad: false, theme: 'base' });

  // Astro renders ```mermaid blocks as <pre><code class="language-mermaid">
  // We need to transform them to <pre class="mermaid"> for the client library
  document.querySelectorAll('pre > code.language-mermaid').forEach(code => {
    const pre = code.parentElement;
    pre.className = 'mermaid';
    pre.textContent = code.textContent;
  });

  await mermaid.run({ querySelector: '.mermaid' });
</script>
