---
import BaseLayout from './BaseLayout.astro';
import 'katex/dist/katex.min.css';
import type { CollectionEntry } from 'astro:content';

interface Props {
  paper: CollectionEntry<'papers'>;
}
const { paper } = Astro.props;
const { title, originalTitle, originalUrl, authors, institution, hfVotes, publishDate, reviewDate, tags, description } = paper.data;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={title} description={description}>
  <a href={base || '/'} class="back-link">← 返回列表</a>

  <article>
    <header class="paper-header">
      <h1 class="paper-title">{title}</h1>
      <p class="paper-original-title">{originalTitle}</p>

      <div class="paper-meta-table">
        <span class="meta-key">原文作者</span>
        <span class="meta-val">{authors}</span>

        {institution && (
          <>
            <span class="meta-key">机构</span>
            <span class="meta-val">{institution}</span>
          </>
        )}

        <span class="meta-key">论文发布</span>
        <span class="meta-val">{publishDate}</span>

        <span class="meta-key">综述日期</span>
        <span class="meta-val">{reviewDate}</span>

        {hfVotes !== undefined && (
          <>
            <span class="meta-key">HF 票数</span>
            <span class="meta-val">🔺 {hfVotes}</span>
          </>
        )}
      </div>

      {tags && tags.length > 0 && (
        <div class="paper-tags">
          {tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      )}

      <a href={originalUrl} target="_blank" rel="noopener noreferrer" class="paper-original-link">
        📄 查看原文 →
      </a>
    </header>

    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<script is:inline src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/svg-pan-zoom@3.6.1/dist/svg-pan-zoom.min.js"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    mermaid.initialize({
      startOnLoad: false,
      theme: 'base',
      themeVariables: {
        fontSize: '15px',
        primaryColor: '#dbeafe',
        primaryTextColor: '#1e293b',
        primaryBorderColor: '#3b82f6',
        lineColor: '#64748b',
        secondaryColor: '#f0fdf4',
        tertiaryColor: '#fef9c3',
      },
    });

    // Astro syntax-highlights mermaid blocks as:
    // <pre class="astro-code" data-language="mermaid"><code><span>…</span></code></pre>
    // Replace with a wrapper + inner div so Mermaid renders, then we apply pan-zoom.
    document.querySelectorAll('pre[data-language="mermaid"]').forEach(function (pre) {
      var wrapper = document.createElement('div');
      wrapper.className = 'mermaid-wrapper';

      var hint = document.createElement('p');
      hint.className = 'mermaid-hint';
      hint.textContent = '滚轮缩放 · 拖拽平移 · 双击复位';
      wrapper.appendChild(hint);

      var inner = document.createElement('div');
      inner.className = 'mermaid';
      inner.textContent = pre.textContent.trim();
      wrapper.appendChild(inner);

      pre.replaceWith(wrapper);
    });

    mermaid.run({ querySelector: '.mermaid' }).then(function () {
      document.querySelectorAll('.mermaid svg').forEach(function (svg) {
        // Make SVG fill the container
        svg.setAttribute('width', '100%');
        svg.setAttribute('height', '100%');
        svg.style.width = '100%';
        svg.style.height = '100%';

        svgPanZoom(svg, {
          zoomEnabled: true,
          controlIconsEnabled: true,
          fit: true,
          center: true,
          minZoom: 0.05,
          maxZoom: 20,
          zoomScaleSensitivity: 0.3,
          dblClickZoomEnabled: false,
          mouseWheelZoomEnabled: true,
          preventMouseEventsDefault: true,
        });
      });
    });
  });
</script>
